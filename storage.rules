rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isBootstrapTeacher() {
      return signedIn()
        && request.auth.uid in [
          'hzSKwkaroTR1LKcXp09E5wL7F6f1'
        ];
    }

    function isTeacher() {
      return isBootstrapTeacher()
        || (
          signedIn()
          && firestore.exists(/databases/(default)/documents/teachers/$(request.auth.uid))
          && firestore.get(/databases/(default)/documents/teachers/$(request.auth.uid)).data.active == true
        );
    }

    match /users/{userId}/attempts/{attemptId}/{fileName} {
      allow read: if isOwner(userId) || isTeacher();

      allow write: if isOwner(userId)
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
